{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "readora",
  "version": "0.2.1",
  "identifier": "com.aspirin.readora",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite dev",
    "beforeBuildCommand": "vite build  --target esnext"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGNkU5ODFENDVCRkRENDEKUldSQjNiOUZIWmh1ai8xNEdXdWkrTHFCRjZySUVKQ3VQdnRIWGNMWEoxR1psdDRoMUtFL2JPeEsK",
      "endpoints": [
        "https://github.com/iFence/readora/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "readora",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' 'unsafe-inline' blob: data: customprotocol: asset: http://asset.localhost ipc: http://ipc.localhost",
        "img-src": "'self' blob: data: asset: http://asset.localhost",
        "style-src": "'self' 'unsafe-inline' blob: asset: http://asset.localhost https://cdn.jsdelivr.net",
        "script-src": "'self' 'unsafe-eval'",
        "object-src": "'none'",
        "frame-src": "'self' asset: http://tauri.localhost blob: data:"
      },
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$PICTURE/**",
            "$RESOURCE/**",
            "$HOME/**",
            "$PUBLIC/**",
            "$APPCACHE/**/*",
            "$TEMP/**/*",
            "/private/var/mobile/Containers/Data/Application/**/*",
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "themes/"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese"
        ]
      },
      "wix": {
        "language": [
          "zh-CN"
        ]
      }
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 800,
          "height": 600
        },
        "appPosition": {
          "x": 180,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 220
        }
      }
    },
    "fileAssociations": [
      {
        "description": "Readora",
        "ext": [
          "epub"
        ]
      }
    ]
  }
}
